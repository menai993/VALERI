# VALERI environment — copy to .env and fill in the secrets.
#   cp .env.example .env
# Never commit .env.

# ── Anthropic API (hosted Claude; request a Zero-Data-Retention agreement for this key) ──
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Model IDs per tier (consumed by litellm.config.yaml; M12: swapping a tier's
#    model — e.g. Sonnet↔Opus — is editing these values + restarting the gateway) ──
LLM_TIER1_MODEL=anthropic/claude-haiku-4-5-20251001
LLM_TIER2_MODEL=anthropic/claude-sonnet-4-6
LLM_TIER2_STRONG_MODEL=anthropic/claude-opus-4-8

# ── LiteLLM gateway ──
LITELLM_MASTER_KEY=REPLACE_ME_RANDOM_STRING
LITELLM_BASE_URL=http://litellm:4000

# ── PostgreSQL ──
POSTGRES_USER=valeri
POSTGRES_PASSWORD=REPLACE_ME_STRONG_PASSWORD
POSTGRES_DB=valeri

# ── PII masking (pseudonym salt - load-bearing, keep secret) ──
PII_SALT=REPLACE_ME_RANDOM_STRING

# ── Auth (M8) — JWT signing secret for session cookies ──
AUTH_SECRET=REPLACE_ME_RANDOM_STRING

# ── App ──
APP_ENV=development
