# VALERI reverse proxy — routes / → web, /api → api (docs/architecture.md §1).
#
# TLS: this default config serves plain HTTP on :80 for LAN/pilot use and is
# TLS-ready — replace :80 with the server's hostname (e.g. valeri.example.com)
# and Caddy will provision certificates automatically; or use
# `tls internal` for a self-signed LAN certificate.

:80 {
	# API → FastAPI service
	handle /api/* {
		reverse_proxy api:8000
	}

	# Everything else → the web bundle
	handle {
		reverse_proxy web:80
	}
}
